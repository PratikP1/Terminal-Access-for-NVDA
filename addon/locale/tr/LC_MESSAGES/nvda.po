# Message when window start is set
#: addon/globalPlugins/terminalAccess.py:6532
msgid "Window start set. Move to end position and press again."
msgstr "Pencere başlangıç seti. Son konuma gidin ve tekrar basın."


# Description for clearing screen window
#: addon/globalPlugins/terminalAccess.py:6551
msgid "Clear screen window"
msgstr "Ekran penceresini temizle"

