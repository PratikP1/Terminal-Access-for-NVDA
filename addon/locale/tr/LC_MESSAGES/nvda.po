#: addon/globalPlugins/terminalAccess.py:4960
msgid "URL"
msgstr "URL"

# Column header for line number
#: addon/globalPlugins/terminalAccess.py:4962
msgid "Line"
msgstr "Çizgi"

# Column header for line context
#: addon/globalPlugins/terminalAccess.py:4964
msgid "Context"
msgstr "Bağlam"

# Button to open URL in browser
#: addon/globalPlugins/terminalAccess.py:4971
msgid "&Open"
msgstr "&Aç"

# Button to copy URL to clipboard
#: addon/globalPlugins/terminalAccess.py:4973
msgid "&Copy URL"
msgstr "URL'yi kopyala"

# Button to move cursor to URL line
#: addon/globalPlugins/terminalAccess.py:4975
msgid "&Move to line"
msgstr "&Satıra git"

#: addon/globalPlugins/terminalAccess.py:4977
msgid "Close"
msgstr "Kapat"

# Announced after URL is copied
#: addon/globalPlugins/terminalAccess.py:5058
msgid "URL copied"
msgstr "URL kopyalandı"

# Announced when moving to a URL line
#: addon/globalPlugins/terminalAccess.py:5069
#, python-brace-format
msgid "Line {num}: {text}"
msgstr "{num} satırı: {text}"

# Position context for verbose mode
#: addon/globalPlugins/terminalAccess.py:5444
#, python-brace-format
msgid "Row {row}, column {col}"
msgstr "Satır{row}, sütun{col}"

# Format for verbose announcements with context
#: addon/globalPlugins/terminalAccess.py:5482
#, python-brace-format
msgid "{message}. {context}"
msgstr "{message}. {context}"

# Message announced when entering a terminal application
#: addon/globalPlugins/terminalAccess.py:5588
msgid "Terminal Access support active. Press NVDA+shift+f1 for help."
msgstr ""
"Terminal Erişimi desteği etkin. Yardım için NVDA+shift+f1 tuşlarına basın."

# Message format for repeated symbols, e.g. "3 dash"
#: addon/globalPlugins/terminalAccess.py:5718
#, python-brace-format
msgid "{count} {symbol}"
msgstr "{count} {symbol}"

#: addon/globalPlugins/terminalAccess.py:5931
#, python-brace-format
msgid "Highlighted: {text}"
msgstr "Vurgulanan: {text}"

# Description for the show help gesture
#: addon/globalPlugins/terminalAccess.py:6019
msgid "Opens the Terminal Access user guide"
msgstr "Terminal Erişimi kullanım kılavuzunu açar"

# Error message when help file is not found
#: addon/globalPlugins/terminalAccess.py:6034
msgid "Help file not found. Please reinstall the add-on."
msgstr "Yardım dosyası bulunamadı. Eklentiyi yeniden yükleyin."

# Error message when add-on is not properly installed
#: addon/globalPlugins/terminalAccess.py:6037
msgid "Terminal Access add-on not properly installed."
msgstr "Terminal Erişimi eklentisi düzgün yüklenmemiş."

# Description for reading the previous line
#: addon/globalPlugins/terminalAccess.py:6041
msgid "Read previous line in terminal"
msgstr "Terminalde önceki satırı oku"

# Description for reading the current line
#: addon/globalPlugins/terminalAccess.py:6055
msgid "Read current line in terminal. Press twice for indentation level."
msgstr "Terminalde mevcut satırı okuyun. Girinti seviyesi için iki kez basın."

# Description for reading the next line
#: addon/globalPlugins/terminalAccess.py:6074
msgid "Read next line in terminal"
msgstr "Terminalde sonraki satırı oku"

# Description for reading the previous word
#: addon/globalPlugins/terminalAccess.py:6088
msgid "Read previous word in terminal"
msgstr "Terminalde önceki kelimeyi oku"

# Description for reading the current word
#: addon/globalPlugins/terminalAccess.py:6102
msgid "Read current word in terminal"
msgstr "Terminalde mevcut kelimeyi oku"

# Description for spelling the current word
#: addon/globalPlugins/terminalAccess.py:6116
msgid "Spell current word in terminal"
msgstr "Terminalde mevcut kelimeyi hecele"

# Description for reading the next word
#: addon/globalPlugins/terminalAccess.py:6130
msgid "Read next word in terminal"
msgstr "Terminalde sonraki kelimeyi oku"

# Description for reading the previous character
#: addon/globalPlugins/terminalAccess.py:6144
msgid "Read previous character in terminal"
msgstr "Terminalde önceki karakteri oku"

# Description for reading the current character
#: addon/globalPlugins/terminalAccess.py:6158
msgid ""
"Read current character in terminal. Press twice for phonetic. Press three "
"times for character code."
msgstr ""
"Terminalde mevcut karakteri okuyun. Fonetik için iki kez basın. Karakter "
"kodu için üç kez basın."

# Description for reading the next character
#: addon/globalPlugins/terminalAccess.py:6182
msgid "Read next character in terminal"
msgstr "Terminalde sonraki karakteri oku"

# Description for toggling quiet mode
#: addon/globalPlugins/terminalAccess.py:6196
msgid "Toggle quiet mode in terminal"
msgstr "Terminalde sessiz modu aç/kapat"

# Message when quiet mode is enabled
#: addon/globalPlugins/terminalAccess.py:6216
msgid "Quiet mode on"
msgstr "Sessiz mod açık"

# Message when quiet mode is disabled
#: addon/globalPlugins/terminalAccess.py:6219
msgid "Quiet mode off"
msgstr "Sessiz mod kapalı"

# Description for toggling announce new output
#: addon/globalPlugins/terminalAccess.py:6223
msgid "Toggle announce new output in terminal"
msgstr "Terminalde yeni çıktıyı duyurma"

# Message when announce new output is enabled
#: addon/globalPlugins/terminalAccess.py:6247
msgid "Announce new output on"
msgstr "Yeni çıktıları duyurun"

# Message when announce new output is disabled
#: addon/globalPlugins/terminalAccess.py:6252
msgid "Announce new output off"
msgstr "Yeni çıktı duyurusu"

# Description for toggling indentation announcement
#: addon/globalPlugins/terminalAccess.py:6256
msgid "Toggle indentation announcement on line read in terminal"
msgstr "Terminalde okunan satırda girinti duyurusunu aç/kapat"

# Message when indentation announcement is enabled
#: addon/globalPlugins/terminalAccess.py:6274
msgid "Indentation announcement on"
msgstr "Girinti duyurusu"

# Message when indentation announcement is disabled
#: addon/globalPlugins/terminalAccess.py:6277
msgid "Indentation announcement off"
msgstr "Girinti duyurusu kapalı"

# Description for copy mode
#: addon/globalPlugins/terminalAccess.py:6281
msgid "Enter copy mode in terminal"
msgstr "Terminalde kopyalama moduna girin"

# Message entering copy mode
#: addon/globalPlugins/terminalAccess.py:6298
msgid ""
"Copy mode. Press L to copy line, S to copy screen, or Escape to cancel."
msgstr ""
"Kopyalama modu. L tuşuna basarak satırı, S tuşuna basarak ekranı kopyalayın "
"veya Escape tuşuna basarak işlemi iptal edin."

# Description for copying line
#: addon/globalPlugins/terminalAccess.py:6302
msgid "Copy line in copy mode"
msgstr "Kopyalama modunda satırı kopyala"

#: addon/globalPlugins/terminalAccess.py:6314
msgid "Unable to copy"
msgstr "Kopyalanamıyor"

# Message when line is copied
#: addon/globalPlugins/terminalAccess.py:6322
msgid "Line copied"
msgstr "Satır kopyalandı"

# Description for copying screen
#: addon/globalPlugins/terminalAccess.py:6333
msgid "Copy screen in copy mode"
msgstr "Kopyalama modunda ekranı kopyala"

# Message when screen is copied
#: addon/globalPlugins/terminalAccess.py:6353
msgid "Screen copied"
msgstr "Ekran kopyalandı"

# Description for exiting copy mode
#: addon/globalPlugins/terminalAccess.py:6364
msgid "Exit copy mode"
msgstr "Kopyalama modundan çık"

# Message when copy mode is canceled
#: addon/globalPlugins/terminalAccess.py:6374
msgid "Copy mode canceled"
msgstr "Kopyalama modu iptal edildi"

# Description for toggling the command layer
#: addon/globalPlugins/terminalAccess.py:6402
msgid "Toggle terminal command layer (single-key command mode)"
msgstr "Terminal komut katmanını değiştir (tek tuşlu komut modu)"

# Announced when the terminal command layer is activated
#: addon/globalPlugins/terminalAccess.py:6431
msgid "Terminal commands"
msgstr "Terminal komutları"

# Announced when the terminal command layer is deactivated
#: addon/globalPlugins/terminalAccess.py:6445
msgid "Exit terminal commands"
msgstr "Çıkış terminali komutları"

# Description for exiting the command layer
#: addon/globalPlugins/terminalAccess.py:6449
msgid "Exit the terminal command layer"
msgstr "Terminal komut katmanından çıkın"

# Description for opening terminal settings
#: addon/globalPlugins/terminalAccess.py:6461
msgid "Open Terminal Access settings"
msgstr "Terminal Erişimi ayarlarını açın"

# Error message when settings dialog cannot be opened
#: addon/globalPlugins/terminalAccess.py:6475
msgid "Unable to open settings dialog. Please try again."
msgstr "Ayarlar iletişim kutusu açılamıyor. Lütfen tekrar deneyin."

# Description for cycling cursor tracking modes
#: addon/globalPlugins/terminalAccess.py:6479
msgid "Cycle cursor tracking mode"
msgstr "Döngü imleci izleme modu"

#: addon/globalPlugins/terminalAccess.py:6502
msgid "Cursor tracking off"
msgstr "İmleç izleme kapalı"

#: addon/globalPlugins/terminalAccess.py:6503
msgid "Standard cursor tracking"
msgstr "Standart imleç izleme"

#: addon/globalPlugins/terminalAccess.py:6504
msgid "Highlight tracking"
msgstr "Önemli kısımları takip etme"

#: addon/globalPlugins/terminalAccess.py:6505
msgid "Window tracking"
msgstr "Pencere izleme"

#: addon/globalPlugins/terminalAccess.py:6507
msgid "Unknown mode"
msgstr "Bilinmeyen mod"

