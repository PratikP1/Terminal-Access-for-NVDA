#~ msgid "&Announce new terminal output automatically"
#~ msgstr "&Annuncia automaticamente l'output del nuovo terminale"

# Tooltip for announce new output
#~ msgid "Automatically speak newly appended terminal output as it arrives. Use NVDA+Shift+N to toggle quickly."
#~ msgstr "Riproduci automaticamente l'output del terminale appena aggiunto non appena arriva. Usa NVDA+Maiusc+N per attivare/disattivare rapidamente questa funzione."

#~ msgid "&Coalesce delay (ms):"
#~ msgstr "&Ritardo di coalescenza (ms):"

# Tooltip for coalesce delay
#~ msgid "Milliseconds to wait before announcing accumulated new output. Larger values reduce interruptions during fast output."
#~ msgstr "Millisecondi di attesa prima di annunciare la nuova output accumulata. Valori più elevati riducono le interruzioni durante l'output veloce."

#~ msgid "&Max lines before summarising:"
#~ msgstr "&Numero massimo di righe prima del riassunto:"

# Tooltip for max lines
#~ msgid "When more than this many lines arrive at once, speak a summary ('N new lines') instead of the full text."
#~ msgstr "Quando arrivano più di questo numero di righe contemporaneamente, pronunciare un riassunto (\"N nuove righe\") invece del testo completo."

#~ msgid "&Strip ANSI escape codes from output"
#~ msgstr "&Rimuovi i codici di escape ANSI dall'output"

# Tooltip for strip ANSI
#~ msgid "Remove ANSI colour and formatting codes before speaking new output."
#~ msgstr "Rimuovi i codici di colore e formattazione ANSI prima di pronunciare il nuovo output."

# Long description to be shown for this add-on on add-on information from add-
# ons manager
#~ msgid "Provides enhanced terminal accessibility for Windows Terminal and PowerShell, enabling screen reader users to efficiently navigate and interact with command-line interfaces. Inspired by TDSR (Terminal Data Structure Reader) and incorporates functionality from both TDSR and Speakup. Advanced features inspired by community suggestions and discussions."
#~ msgstr "Fornisce una maggiore accessibilità al terminale per Windows Terminal e PowerShell, consentendo agli utenti di screen reader di navigare e interagire in modo efficiente con le interfacce a riga di comando. Ispirato a TDSR (Terminal Data Structure Reader), incorpora funzionalità sia di TDSR che di Speakup. Funzionalità avanzate ispirate dai suggerimenti e dalle discussioni della comunità."

#~ msgid "Terminal Access for NVDA"
#~ msgstr "Accesso al terminale per NVDA"
