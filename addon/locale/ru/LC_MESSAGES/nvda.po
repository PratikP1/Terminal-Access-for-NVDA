# Message when unable to start continuous reading
#: addon/globalPlugins/terminalAccess.py:6707
msgid "Unable to read"
msgstr "Невозможно прочитать"

# Message when buffer is empty
#: addon/globalPlugins/terminalAccess.py:6720
msgid "Nothing to read"
msgstr "Нечего читать"

