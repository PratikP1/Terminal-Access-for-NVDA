msgid "Move to first character of current line"
msgstr "Перейти к первому символу текущей строки"

# Message when unable to move
#: addon/globalPlugins/terminalAccess.py:6747
msgid "Unable to move"
msgstr "Невозможность двигаться"

# Message for blank line
#: addon/globalPlugins/terminalAccess.py:6765
msgid "Blank"
msgstr "Пустой"

