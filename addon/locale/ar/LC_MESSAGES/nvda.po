msgstr "حدد ملف تعريف التطبيق لعرضه أو تحريره. تعمل ملفات التعريف على تخصيص سلوك الوصول إلى المحطة الطرفية لتطبيقات معينة. يتم تمييز ملفات التعريف النشطة والافتراضية."

# Label for new profile button
#: addon/lib/settings_panel.py:407
msgid "&New Profile..."
msgstr "&ملف تعريف جديد..."

# Tooltip for new profile button
#: addon/lib/settings_panel.py:411
msgid "Create a new application profile with custom settings"
msgstr "إنشاء ملف تعريف تطبيق جديد بإعدادات مخصصة"

# Label for edit profile button
#: addon/lib/settings_panel.py:416
msgid "&Edit Profile..."
msgstr "&تحرير الملف الشخصي..."

# Tooltip for edit profile button
#: addon/lib/settings_panel.py:420
msgid "Edit the selected application profile"
msgstr "تحرير ملف تعريف التطبيق المحدد"

# Label for delete profile button
#: addon/lib/settings_panel.py:425
msgid "&Delete Profile"
msgstr "&حذف الملف الشخصي"

# Tooltip for delete profile button
#: addon/lib/settings_panel.py:429
msgid "Delete the selected custom profile (default profiles cannot be deleted)"
msgstr "حذف ملف التعريف المخصص المحدد (لا يمكن حذف ملفات التعريف الافتراضية)"

# Label for import profile button
#: addon/lib/settings_panel.py:439
msgid "&Import..."
msgstr "&استيراد..."

# Tooltip for import profile button
#: addon/lib/settings_panel.py:443
msgid "Import a profile from a JSON file"
msgstr "استيراد ملف تعريف من ملف JSON"

# Label for export profile button
#: addon/lib/settings_panel.py:448
msgid "E&xport..."
msgstr "تصدير..."

# Tooltip for export profile button
#: addon/lib/settings_panel.py:452
msgid "Export the selected profile to a JSON file"
msgstr "تصدير الملف الشخصي المحدد إلى ملف JSON"

#: addon/lib/settings_panel.py:479
msgid "Are you sure you want to reset all Terminal Access settings to their default values?"
msgstr "هل تريد بالفعل إعادة ضبط جميع إعدادات الوصول إلى Terminal إلى قيمها الافتراضية؟"

#: addon/lib/settings_panel.py:480
msgid "Confirm Reset"
msgstr "تأكيد إعادة الضبط"

#: addon/lib/settings_panel.py:517
msgid "All settings have been reset to their default values."
msgstr "تمت إعادة ضبط جميع الإعدادات إلى قيمها الافتراضية."

#: addon/lib/settings_panel.py:518
msgid "Settings Reset"
msgstr "إعادة ضبط الإعدادات"

# Indicator for currently active profile
#: addon/lib/settings_panel.py:626
msgid "Active"
msgstr "نشط"

# Indicator for default profile
#: addon/lib/settings_panel.py:629
msgid "Default"
msgstr "الافتراضي"

#: addon/lib/settings_panel.py:670
msgid "Profile creation dialog will be implemented soon. For now, profiles can be created programmatically via the ProfileManager API."
msgstr "سيتم تنفيذ مربع حوار إنشاء الملف الشخصي قريبًا. في الوقت الحالي، يمكن إنشاء الملفات الشخصية برمجيًا عبر واجهة برمجة التطبيقات ProfileManager."

#: addon/lib/settings_panel.py:672 addon/lib/settings_panel.py:686
msgid "Feature In Development"
msgstr "ميزة قيد التطوير"

#: addon/lib/settings_panel.py:684
#, python-brace-format
msgid "Profile editing dialog will be implemented soon. Selected profile: {name}"
msgstr "سيتم تنفيذ مربع حوار تحرير الملف الشخصي قريبًا. الملف الشخصي المحدد: {name}"

#: addon/lib/settings_panel.py:698
#, python-brace-format
msgid "Are you sure you want to delete the profile '{name}'?"
msgstr "هل أنت متأكد من أنك تريد حذف ملف التعريف \"{name}\"؟"

#: addon/lib/settings_panel.py:699
msgid "Confirm Delete"
msgstr "تأكيد الحذف"

#: addon/lib/settings_panel.py:716
#, python-brace-format
msgid "Profile '{name}' has been deleted."
msgstr "تم حذف ملف تعريف \"{name}\"."

#: addon/lib/settings_panel.py:717
msgid "Profile Deleted"
msgstr "تم حذف الملف الشخصي"

#: addon/lib/settings_panel.py:726
msgid "Failed to delete profile. See NVDA log for details."
msgstr "فشل حذف الملف الشخصي. انظر سجل NVDA للحصول على التفاصيل."

#: addon/lib/settings_panel.py:727
msgid "Error"
msgstr "خطأ"

#: addon/lib/settings_panel.py:736
msgid "Import Profile"
msgstr "استيراد الملف الشخصي"

#: addon/lib/settings_panel.py:738 addon/lib/settings_panel.py:800
msgid "JSON files (*.json)|*.json"
msgstr "ملفات JSON (*.json)|*.json"

#: addon/lib/settings_panel.py:762
#, python-brace-format
msgid "Profile '{name}' has been imported successfully."
msgstr "تم استيراد ملف التعريف \"{name}\" بنجاح."

#: addon/lib/settings_panel.py:765
msgid "Profile Imported"
msgstr "الملف الشخصي المستورد"

#: addon/lib/settings_panel.py:774
msgid "Failed to import profile. The file may be invalid or corrupted."
msgstr "فشل استيراد ملف التعريف. قد يكون الملف غير صالح أو تالف."

#: addon/lib/settings_panel.py:775
msgid "Import Error"
msgstr "خطأ في الاستيراد"

#: addon/lib/settings_panel.py:797
msgid "Export Profile"
msgstr "ملف التصدير"

#: addon/lib/settings_panel.py:813
#, python-brace-format
msgid "Profile '{name}' has been exported successfully."
msgstr "تم تصدير ملف التعريف \"{name}\" بنجاح."

#: addon/lib/settings_panel.py:814
msgid "Profile Exported"
msgstr "ملف تعريف تم تصديره"

#: addon/lib/settings_panel.py:823
msgid "Failed to export profile. See NVDA log for details."
msgstr "فشل تصدير ملف التعريف. انظر سجل NVDA للحصول على التفاصيل."

#: addon/lib/settings_panel.py:824
msgid "Export Error"
msgstr "خطأ في التصدير"

